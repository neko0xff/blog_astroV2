    "@std/internal": "jsr:@std/internal@^1.0.14",
    "@std/cli": "jsr:@std/cli@^1.0.30",
    "@std/net": "jsr:@std/net@^1.0.6",
    "@std/html": "jsr:@std/html@^1.0.7",
    "react": "npm:react@^19.2.4",
    "react-dom": "npm:react-dom@^19.2.4",

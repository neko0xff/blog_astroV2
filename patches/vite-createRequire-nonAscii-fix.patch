Description: Fix Vite 7.x createRequire failing with non-ASCII paths (Chinese characters) in Deno
Root Cause: Vite's resolveExtends() uses createRequire(from) where `from` is a plain file path.
            Deno's node:module polyfill cannot parse paths with non-ASCII characters as URLs,
            throwing "Invalid URL" for paths like /home/user/文件/...
Fix: Convert the `from` path to a file:// URL before passing to createRequire.

--- a/node_modules/.deno/vite@7.3.3/node_modules/vite/dist/node/chunks/config.js
+++ b/node_modules/.deno/vite@7.3.3/node_modules/vite/dist/node/chunks/config.js
@@ -5795,7 +5795,9 @@
 function resolveExtends(extended, from) {
 	if ([".", ".."].includes(extended)) extended = extended + "/tsconfig.json";
-	const req$4 = createRequire$1(from);
+	let fromUrl;
+	try { fromUrl = new URL(`file://${from}`); } catch { fromUrl = from; }
+	const req$4 = createRequire(fromUrl);
 	let error$1;
 	try {
 		return req$4.resolve(extended);

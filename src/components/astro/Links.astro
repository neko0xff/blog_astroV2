---
import { LINKS } from "@/data/links";
---

<div>
  <p class="text-right text-xs">
    📧:
    <a class="link" href="mailto:chzang55@gmail.com">
      chzang55@gmail.com
    </a>
  </p>
  <br />
  {
    LINKS.length > 0 ? (
      <div class="mb-3 grid grid-cols-1 gap-3.5 md:grid-cols-2">
        {
          LINKS.map((link) => (
            <a
              href={link.siteURL}
              class="flex items-center overflow-hidden border-r-2 border-b-2 border-border no-underline transition-all duration-300 hover:-translate-y-1"
            >
              <img
                class="h-24 w-24 shrink-0 object-cover"
                src={link.icon}
                alt={`avatar${link.name}`}
                loading="lazy"
              />
              <div class="min-w-0 px-4 py-5">
                <div class="truncate text-sm font-medium text-slate-900 sm:text-base dark:text-slate-200">
                  {link.name}
                </div>
                <div class="truncate text-sm leading-tight font-medium text-slate-500 sm:text-base dark:text-slate-400">
                  {link.site}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    ) : (
      <p class="text-center">暫無友站鏈結</p>
    )
  }
</div>

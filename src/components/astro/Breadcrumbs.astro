---
// Route label mapping
const ROUTE_LABELS: Record<string, string> = {
  posts: "文章",
  archives: "歸檔",
  about: "關於",
  terms: "條款",
  links: "友站連結",
  search: "搜尋",
  tags: "標籤",
};

// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

// Normalize route segments to display labels
if (breadcrumbList[0] in ROUTE_LABELS) {
  const route = breadcrumbList[0];

  // Handle paginated routes: /posts/2, /archives/3, /tags/[tag]/2
  if ((route === "posts" || route === "archives") && breadcrumbList[1]) {
    breadcrumbList.splice(0, 2, `${ROUTE_LABELS[route]} (第 ${breadcrumbList[1]} 頁)`);
  } else if (
    route === "tags" &&
    breadcrumbList[2] &&
    !isNaN(Number(breadcrumbList[2]))
  ) {
    const pageLabel = Number(breadcrumbList[2]) === 1 ? "" : `(第 ${breadcrumbList[2]}頁)`;
    breadcrumbList.splice(1, 3, `${breadcrumbList[1]} ${pageLabel}`);
  } else if (breadcrumbList.length === 1 || route !== "tags") {
    breadcrumbList[0] = ROUTE_LABELS[route];
  }
}
---

<nav class="mx-auto mt-8 mb-1 w-full max-w-3xl px-4" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href="/" class="opacity-80">主頁</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) => {
        const isLast = index === breadcrumbList.length - 1;
        const decoded = decodeURIComponent(breadcrumb);
        return isLast ? (
          <li>
            <span
              class={`capitalize opacity-75${index > 0 ? " lowercase" : ""}`}
              aria-current="page"
            >
              {decoded}
            </span>
          </li>
        ) : (
          <li>
            <a href={`/${breadcrumb}/`} class="capitalize opacity-70">
              {decoded}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        );
      })
    }
  </ul>
</nav>
<br />
